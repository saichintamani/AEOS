# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/

# ── Test / tooling caches ─────────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

