# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/

# ── Test / tooling caches ─────────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ── Secrets / local config ────────────────────────────────────────────────────
.env
*.local

# ── Runtime data & generated artifacts ────────────────────────────────────────
data/model_registry/*.pkl
data/model_registry/*.joblib
data/model_registry/*_meta.json
data/**/*.sqlite*
data/**/*.db
*.log

# ── Secrets: signing keys (NEVER commit private keys) ─────────────────────────
data/keys/

# ── Terraform: local provider cache, state, and plan binaries ─────────────────
**/.terraform/
*.tfstate
*.tfstate.*
*.tfplan
infrastructure/terraform/environments/*/*.plan
infrastructure/terraform/environments/*/plan-show.txt
infrastructure/terraform/environments/*/plan-show.err

# ── Generated benchmark / certification output ────────────────────────────────
benchmark_results/
reports/

# ── Claude Code tooling (not part of the project) ─────────────────────────────
.claude/

# ── OS / editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/

data/rag/

# ── Proto generated stubs (rebuilt by buf generate in CI) ─────────────────────
app/distributed/grpc/generated/**/*_pb2.py
app/distributed/grpc/generated/**/*_pb2_grpc.py
app/distributed/grpc/generated/**/*_pb2.pyi
# Keep the __init__.py placeholders (package markers, not generated stubs)
!app/distributed/grpc/generated/**/__init__.py
