# ─────────────────────────────────────────────
# AEOS Environment Configuration
# Copy to .env and fill in values
# NEVER commit .env to version control
# ─────────────────────────────────────────────

# Identity
APP_NAME=AEOS
APP_VERSION=0.1.0
ENVIRONMENT=development         # development | staging | production

# API
API_PREFIX=/api/v1
API_HOST=0.0.0.0
API_PORT=8000

# Debug (set false in production)
DEBUG=true

# Orchestrator
DEFAULT_AGENT=simple_agent
AGENT_TIMEOUT_SECONDS=60
MAX_RETRIES=3

# Logging
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
LOG_JSON=false                  # true = JSON (production), false = human (dev)

# RAG Engine
CHROMA_HOST=                    # empty = in-memory (no Docker needed); set host for persistent mode
CHROMA_PORT=8001
CHROMA_COLLECTION=aeos_default
EMBEDDING_MODEL=all-MiniLM-L6-v2
RAG_TOP_K=5
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64

# GitHub Analyzer (optional — works unauthenticated at 60 req/hr)
GITHUB_TOKEN=
GITHUB_API_URL=https://api.github.com

# ML Pipeline
ML_MODEL_REGISTRY_PATH=./data/model_registry
ML_DATASET_PATH=./data/datasets

# Shared Memory
MEMORY_MAX_LONG_TERM=1000       # max long-term entries before LRU eviction
MEMORY_SHORT_TERM_TTL_SECONDS=3600  # informational; short-term is cleared on task end

# Message Bus
MESSAGE_BUS_MAX_QUEUE=500       # max pending messages per topic
